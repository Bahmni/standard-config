{
  "sources": {
    "patient": {
      "api": "fhir",
      "resource": "Patient",
      "params": {
        "_id": "{{patientUuid}}"
      }
    },
    "relatives": {
      "api": "fhir",
      "resource": "RelatedPerson",
      "params": {
        "patient": "{{patientUuid}}"
      }
    }
  },
  "computed": {
    "patientName": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.name.first().text"
    },
    "patientId": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.identifier.where(use = 'official').first().value"
    },
    "birthDate": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.birthDate"
    },
    "gender": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.gender"
    },
    "phone": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.telecom.where(system = 'phone').first().value"
    },
    "address": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.address.first().text"
    },
    "photoUrl": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.photo.first().url"
    },
    "registrationDate": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.identifier.where(use = 'official').first().period.start"
    },
    "village": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.address.first().city"
    },
    "tehsil": {
      "fn": "fhirPath",
      "source": "patient",
      "expr": "Bundle.entry.first().resource.address.first().district"
    },
    "nextOfKinName": {
      "fn": "fhirPath",
      "source": "relatives",
      "expr": "Bundle.entry.first().resource.name.first().text"
    },
    "nextOfKinRelationship": {
      "fn": "fhirPath",
      "source": "relatives",
      "expr": "Bundle.entry.first().resource.relationship.first().text"
    }
  }
}
