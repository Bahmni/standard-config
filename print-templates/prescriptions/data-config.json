{
  "sources": {
    "patient": {
      "api": "fhir",
      "resource": "Patient",
      "params": {
        "_id": "{{patientUUID}}"
      }
    },
    "medicationRequests": {
      "api": "fhir",
      "resource": "MedicationRequest",
      "params": {
        "patient": "{{patientUUID}}",
        "_include": ["MedicationRequest:encounter", "MedicationRequest:medication"],
        "_sort": "-_lastUpdated",
        "_count": "100"
      }
    }
  }
}
